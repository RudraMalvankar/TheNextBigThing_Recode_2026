PORT=5000
NODE_ENV=development

# CORS origins
CLIENT_URL=http://localhost:5173
CLIENT_ORIGIN=http://localhost:5173

# Database (set either one)
MONGO_URI=mongodb://localhost:27017/insightos
# MONGODB_URI=

# Redis (choose URL or host/port form)
# REDIS_URL=redis://localhost:6379
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_USERNAME=
REDIS_PASSWORD=
REDIS_TLS=off

# Auth
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=15m
AUTH_EMAIL=admin@insightos.local
AUTH_PASSWORD=admin123
AUTH_NAME=Personal Admin

# If true, funnel route seeds defaults when missing
AUTO_SEED_FUNNEL=true
